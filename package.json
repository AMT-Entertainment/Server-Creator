{
  "name": "server-creator",
  "version": "1.3.2",
  "description": "Server Creator by AMT Entertainment - Minecraft Server Manager",
  "main": "dist/electron/main.js",
  "scripts": {
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:react": "webpack --mode production",
    "build": "npm run build:electron && npm run build:react",
    "dev:electron": "tsc -p tsconfig.electron.json",
    "dev:react": "webpack --mode development --watch",
    "start": "npm run build:electron && npm run build:react && electron .",
    "dev": "npm run build:electron && webpack --mode development && electron .",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:all": "npm run build && electron-builder --mac --win"
  },
  "build": {
    "appId": "com.amtentertainment.server-creator",
    "productName": "Server Creator",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "build-assets/icon.png",
      "node_modules/**/*"
    ],
    "extraMetadata": {
      "main": "dist/electron/main.js"
    },
    "publish": {
      "provider": "github",
      "owner": "AMT-Entertainment",
      "repo": "Server-Creator",
      "releaseType": "release"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build-assets/icon.icns",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "build-assets/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build-assets/icon.ico",
      "uninstallerIcon": "build-assets/icon.ico"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "i18next": "^23.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^13.3.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.8.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "html-webpack-plugin": "^5.5.0",
    "style-loader": "^3.3.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0"
  }
}
